  "faq1Question": "How do I change my calorie goal?",
  "@faq1Question": {
    "description": "FAQ question 1"
  },
  "faq1Answer": "Go to More > Diet Preferences, then adjust your calorie target and macro split.",
  "@faq1Answer": {
    "description": "FAQ answer 1"
  },
  "faq2Question": "Can I track water reminders?",
  "@faq2Question": {
    "description": "FAQ question 2"
  },
  "faq2Answer": "Yes. Go to More > Notifications and enable water reminders. You can set the interval between 1-4 hours.",
  "@faq2Answer": {
    "description": "FAQ answer 2"
  },
  "faq3Question": "How do I reset my password?",
  "@faq3Question": {
    "description": "FAQ question 3"
  },
  "faq3Answer": "Go to More > Change Password. Enter your current password, then your new password twice.",
  "@faq3Answer": {
    "description": "FAQ answer 3"
  },
  "faq4Question": "How is my daily calorie target calculated?",
  "@faq4Question": {
    "description": "FAQ question 4"
  },
  "faq4Answer": "Your target is based on your age, gender, height, weight, activity level, and selected goal (lose/maintain/gain).",
  "@faq4Answer": {
    "description": "FAQ answer 4"
  },
  "faq5Question": "Can I use Afia offline?",
  "@faq5Question": {
    "description": "FAQ question 5"
  },
  "faq5Answer": "Basic logging features work offline. Syncing across devices requires an internet connection.",
  "@faq5Answer": {
    "description": "FAQ answer 5"
  },
  "faq6Question": "How do I change my language preference?",
